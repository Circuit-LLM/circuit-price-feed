# circuit-price-feed — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# Redis connection — circuit-indexer writes live reserve prices and OHLCV candles here.
# Format: redis://[:password@]host:port
REDIS_URL=redis://:your_redis_password@localhost:6379

# HTTP port the feed listens on (loopback only in production).
PORT=18941

# Solana RPC endpoint — used for Pump.fun PDA / pool-reserve lookups on a Redis cache miss.
# Any standard Solana RPC URL works (Helius, Triton, QuickNode, etc.).
CIRCUIT_RPC_URL=https://your-rpc-provider.example/?api-key=YOUR_KEY
